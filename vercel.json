{
  "version": 2,
  "cleanUrls": true,
  "rewrites": [
    { "source": "/functions/v1/send-utmify-order", "destination": "/api/webhook-alphacash" },
    { "source": "/functions/v1/:path*", "destination": "/api/webhook-alphacash" },
    { "source": "/json", "destination": "/api/webhook-alphacash" },
    { "source": "/api/create-pix-transaction", "destination": "/api/create-pix-transaction" },
    { "source": "/api/check-transaction-status", "destination": "/api/check-transaction-status" },
    { "source": "/((?!api/|functions/|_next/|static/|products/).*\\..*)", "destination": "/$1" },
    { "source": "/((?!api/|functions/|_next/|static/|products/).*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "GET,OPTIONS,PATCH,DELETE,POST,PUT" },
        { "key": "Access-Control-Allow-Headers", "value": "*" }
      ]
    }
  ]
}
